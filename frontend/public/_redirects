# Security headers for production
/*  X-Frame-Options: DENY
/*  X-Content-Type-Options: nosniff
/*  Referrer-Policy: strict-origin-when-cross-origin
/*  X-XSS-Protection: 1; mode=block
/*  Strict-Transport-Security: max-age=31536000; includeSubDomains
/*  X-DNS-Prefetch-Control: on
/*  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Static assets - serve with aggressive caching
/assets/*  /assets/:splat  200! Cache-Control: public,max-age=31536000,immutable
/icons/*   /icons/:splat   200! Cache-Control: public,max-age=31536000,immutable

# PWA files
/manifest.webmanifest  /manifest.webmanifest  200! Cache-Control: public,max-age=86400
/sw.js     /sw.js         200! Cache-Control: public,max-age=0,must-revalidate

# Favicon files
/favicon.ico /favicon.ico  200! Cache-Control: public,max-age=86400
/favicon.svg /favicon.svg  200! Cache-Control: public,max-age=86400
/favicon.txt /favicon.txt  200! Cache-Control: public,max-age=86400

# API proxy to backend (for development/fallback)
/api/*  https://school-report-saas.onrender.com/api/:splat  200! Cache-Control: no-cache,no-store,must-revalidate

# Preload critical resources for main page
/  /index.html  200  Link: </assets/css/index.css>; rel=preload; as=style, </assets/js/index.js>; rel=preload; as=script

# HTML files - no cache to ensure updates
/*.html  /:splat.html  200! Cache-Control: public,max-age=0,must-revalidate

# All other routes go to index.html for SPA (must be last)
/*  /index.html  200