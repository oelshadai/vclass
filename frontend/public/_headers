# JavaScript files
/assets/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

# CSS files
/assets/*.css
  Content-Type: text/css
  Cache-Control: public, max-age=31536000, immutable

# Module JavaScript files
/assets/*.mjs
  Content-Type: application/javascript
  Cache-Control: public, max-age=31536000, immutable

# Root JavaScript files
/*.js
  Content-Type: application/javascript
  Cache-Control: public, max-age=86400

# Root CSS files
/*.css
  Content-Type: text/css
  Cache-Control: public, max-age=86400

# Root Module JavaScript files
/*.mjs
  Content-Type: application/javascript
  Cache-Control: public, max-age=86400

# Security headers for all pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://school-report-saas.onrender.com; frame-ancestors 'none';
  Permissions-Policy: camera=(), microphone=(), geolocation=()